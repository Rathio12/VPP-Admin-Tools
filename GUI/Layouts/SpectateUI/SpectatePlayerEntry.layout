PanelWidgetClass EntryRoot {
 visible 1
 ignorepointer 0
 color 0.106 0.118 0.133 0.85
 size 1 26
 halign center_ref
 hexactpos 0
 vexactpos 0
 hexactsize 0
 vexactsize 1
 style VPPFillRound
 {
  ImageWidgetClass ImgOnlineDot {
   ignorepointer 1
   color 0.298 0.686 0.314 1
   position 4 0
   size 24 24
   valign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 1
   vexactsize 1
   image0 "set:vpp_icons image:dot"
   mode blend
   "src alpha" 1
   "stretch mode" stretch_w_h
   filter 1
  }
  TextWidgetClass TxtRowName {
   ignorepointer 1
   color 0.882 0.894 0.906 1
   position 26 0
   size 0.7 1
   valign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 0
   vexactsize 0
   style None
   text "PlayerName"
   font "gui/fonts/sdf_MetronLight72"
   "exact text" 1
   "exact text size" 13
   "size to text h" 1
   "size to text v" 1
   "text valign" center
  }
  ButtonWidgetClass BtnRowSpectate {
   ignorepointer 0
   color 1 1 1 1
