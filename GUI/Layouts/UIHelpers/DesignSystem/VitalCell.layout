   ignorepointer 1
   color 0.604 0.627 0.651 1
   position 0 0
   size 13 13
   halign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 1
   vexactsize 1
   image0 "set:vpp_icons image:heart_pulse"
   mode blend
   "src alpha" 1
   "stretch mode" stretch_w_h
   filter 1
  }
  TextWidgetClass VitalCellValue {
   ignorepointer 1
   position 0 15
