PanelWidgetClass PanelPlayer {
 visible 1
 ignorepointer 1
 keepsafezone 1
 color 0.106 0.118 0.133 1
 position 0 0
 size 1 26
 halign center_ref
 hexactpos 1
 vexactpos 1
 hexactsize 0
 vexactsize 1
 style VPPFillRound
 {
  ImageWidgetClass ImgOnlineDot {
   ignorepointer 1
   color 0.298 0.686 0.314 1
   position 8 0
   size 8 8
   valign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 1
   vexactsize 1
   image0 "set:vpp_icons image:dot"
   mode blend
   "src alpha" 1
   "stretch mode" stretch_w_h
   filter 1
  }
  CheckBoxWidgetClass CheckBox {
   ignorepointer 0
   position 24 0
   size 0.88 0.9
   valign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 0
   vexactsize 0
   style VPPCheckBox
   text "PlayerName"
   font "vppadmintools/gui/fonts/InterDisplay-Regular16"
   "text outline size" 1
   "text outline color" 0 0 0 0.9961
   "text shadow color" 0 0 0 0
   checked 0
  }
 }
}
