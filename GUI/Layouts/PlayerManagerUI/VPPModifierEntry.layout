FrameWidgetClass ModifierEntryRoot {
 ignorepointer 1
 position 0 0
 size 1 26
 hexactpos 1
 vexactpos 1
 hexactsize 0
 vexactsize 1
 {
  ImageWidgetClass ModEntryDot {
   ignorepointer 1
   color 0.604 0.627 0.651 1
   position 8 0
   size 16 16
   valign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 1
   vexactsize 1
   image0 "set:vpp_icons image:dot"
   mode blend
   "src alpha" 1
   "stretch mode" stretch_w_h
   filter 1
  }
  TextWidgetClass ModEntryName {
   ignorepointer 1
   position 26 0
   size 0.6 1
   valign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 0
   vexactsize 0
   style None
   text "Modifier"
   font "gui/fonts/sdf_MetronLight72"
   "bold text" 1
   "exact text" 1
   "exact text size" 14
   "size to text h" 1
   "size to text v" 1
   "text valign" center
  }
  ButtonWidgetClass ModEntryToggle {
   disabled 0
   color 1 1 1 1
   position 8 0
   size 76 20
   halign right_ref
   valign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 1
   vexactsize 1
   style VPPButton
   {
    TextWidgetClass ModEntryToggleLbl {
     ignorepointer 1
     halign center_ref
     valign center_ref
     hexactpos 1
     vexactpos 1
     hexactsize 0
     vexactsize 0
     style None
     text "Add"
     font "gui/fonts/sdf_MetronLight72"
     "exact text" 1
     "exact text size" 14
     "size to text h" 1
     "size to text v" 1
     "text valign" center
    }
   }
  }
 }
}