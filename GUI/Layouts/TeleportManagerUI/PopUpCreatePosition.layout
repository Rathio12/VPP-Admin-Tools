     ignorepointer 1
     color 0.91 0.639 0.239 1
     position 0 0
     size 28 28
     valign center_ref
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     image0 "set:vpp_icons image:map_pin_plus"
     mode blend
     "src alpha" 1
     "stretch mode" stretch_w_h
     filter 1
    }
