PanelWidgetClass rootFrame {
 position 25 0
 size 420 190
 halign center_ref
 valign center_ref
 hexactpos 1
 vexactpos 1
 hexactsize 1
 vexactsize 1
 scriptclass "PopUpNewPositionEditor"
 style VPPPanel
 {
  PanelWidgetClass PopUpTitleStrip {
   ignorepointer 1
   color 0.039 0.043 0.047 0.85
   position 0 1
   size 0.99 28
   halign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 0
   vexactsize 1
   style VPPFillRound
   {
