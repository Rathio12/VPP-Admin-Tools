FrameWidgetClass PanelEntry {
 ignorepointer 1
 keepsafezone 1
 color 0 0 0 1
 position 0 0
 size 1 28
 hexactpos 1
 vexactpos 1
 hexactsize 0
 vexactsize 1
 {
  PanelWidgetClass entry_content {
   ignorepointer 0
   color 0.075 0.086 0.094 1
   size 0.99 1
   halign center_ref
   valign center_ref
   hexactpos 0
   vexactpos 0
   hexactsize 0
   vexactsize 0
   style VPPInputPanel
   {
    ButtonWidgetClass btnDeleteItem {
     color 1 1 1 1
     position 0 0
     size 28 28
     halign right_ref
     valign center_ref
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     scriptclass "ConfirmationEventHandler"
     style VPPButtonGhost
     "no focus" 1
     {
      ImageWidgetClass iconDel {
       ignorepointer 1
       color 0.761 0.271 0.271 1
       position 0 0
       size 24 24
       halign center_ref
       valign center_ref
       hexactpos 1
       vexactpos 1
       hexactsize 1
       vexactsize 1
       image0 "set:vpp_icons image:trash_2"
       mode blend
       "src alpha" 1
       "stretch mode" stretch_w_h
       filter 1
      }
     }
    }
    CheckBoxWidgetClass Active {
     position 0.015 0
     size 0.075 0.6
     valign center_ref
     hexactpos 0
     vexactpos 0
     hexactsize 0
     vexactsize 0
     scriptclass "ConfirmationEventHandler"
     style VPPCheckBox
    }
    ButtonWidgetClass btnEditItem {
     color 1 1 1 1
     position 27 0
     size 28 28
     halign right_ref
     valign center_ref
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     scriptclass ""
     style VPPButtonGhost
     "no focus" 1
     {
      ImageWidgetClass iconEdit {
       ignorepointer 1
       color 0.604 0.627 0.651 1
       position 0 0
       size 24 24
       halign center_ref
       valign center_ref
       hexactpos 1
       vexactpos 1
       hexactsize 1
       vexactsize 1
       image0 "set:vpp_icons image:square_pen"
       mode blend
       "src alpha" 1
       "stretch mode" stretch_w_h
       filter 1
      }
     }
    }
    TextWidgetClass ItemName {
     ignorepointer 1
     color 0.953 0.961 0.969 1
     position 0.05 0
     size 0.9 1
     halign center_ref
     valign center_ref
     hexactpos 0
     vexactpos 0
     hexactsize 0
     vexactsize 0
     style None
     text "Item Display Name"
     font "gui/fonts/sdf_MetronLight72"
     "bold text" 1
     "exact text" 1
     "exact text size" 14
     "size to text h" 0
     "size to text v" 1
     "text valign" center
    }
   }
  }
 }
}