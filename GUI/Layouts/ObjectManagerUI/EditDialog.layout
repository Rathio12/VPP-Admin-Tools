PanelWidgetClass rootFrame {
 color 1 1 1 1
 size 0.45 0.45
 halign center_ref
 valign center_ref
 hexactpos 0
 vexactpos 0
 hexactsize 0
 vexactsize 0
 style VPPPanel
 {
  PanelWidgetClass PnlBg {
   ignorepointer 1
   color 0.055 0.063 0.071 0.6
   position 0 0.13
   size 0.96 0.74
   halign center_ref
   hexactpos 0
   vexactpos 0
   hexactsize 0
   vexactsize 0
   style VPPCard
  }
  ImageWidgetClass IconDlg {
   ignorepointer 1
   color 0.91 0.639 0.239 1
   position 0.01 5
   size 24 24
   hexactpos 0
   vexactpos 1
   hexactsize 1
   vexactsize 1
   image0 "set:vpp_icons image:settings"
   mode blend
   "src alpha" 1
   "stretch mode" stretch_w_h
   filter 1
  }
  TextWidgetClass text_title {
   ignorepointer 1
   position 0.12 0
   size 0.8 0.12
   hexactpos 0
   vexactpos 0
   hexactsize 0
   vexactsize 0
   style None
   text "#VSTR_LBL_BUILDING_SET_ATTS"
   font "gui/fonts/sdf_MetronLight72"
   "bold text" 1
   "exact text" 1
   "exact text size" 16
   "size to text h" 0
   "text valign" center
  }
  ButtonWidgetClass panel_close {
   ignorepointer 0
   size 32 32
   halign right_ref
   hexactpos 0
   vexactpos 1
   hexactsize 1
   vexactsize 1
   style VPPButtonGhost
   {
    ImageWidgetClass button_close {
     ignorepointer 1
     color 0.604 0.627 0.651 1
     size 24 24
     halign center_ref
     valign center_ref
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     image0 "set:vpp_icons image:x"
     mode blend
     "src alpha" 1
     "stretch mode" stretch_w_h
     filter 1
    }
   }
  }
  PanelWidgetClass panel_redline {
   ignorepointer 1
   color 0.91 0.639 0.239 1
   position 0 0.12
   size 1 0.004
   halign center_ref
   hexactpos 0
   vexactpos 0
   hexactsize 0
   vexactsize 0
   style VPPFill
  }
  GridSpacerWidgetClass panel_content {
   ignorepointer 0
   position 0 0
   size 0.86 0.8
   halign center_ref
   valign center_ref
   hexactpos 0
   vexactpos 0
   hexactsize 0
   vexactsize 0
   Padding 6
   "Size To Content H" 1
   "Size To Content V" 1
   Columns 1
   {
    EditBoxWidgetClass InputSetName {
     size 1 0.2
     halign center_ref
     valign center_ref
     hexactpos 0
     vexactpos 0
     hexactsize 0
     vexactsize 0
     style VPPInput
     text "#VSTR_LBL_BUILDING_SET_NAME"
     "Use default text" 0
     "exact text" 1
     font "gui/fonts/sdf_MetronLight24"
     "text halign" center
     "text valign" center
    }
    CheckBoxWidgetClass checkbox_active {
     size 0.5 0.2
     halign center_ref
     valign center_ref
     hexactpos 0
     vexactpos 0
     hexactsize 0
     vexactsize 0
