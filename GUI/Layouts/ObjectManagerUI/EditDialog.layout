     "no focus" 1
     font "gui/fonts/sdf_MetronLight72"
     {
      ImageWidgetClass iconExport {
       ignorepointer 1
       color 0.604 0.627 0.651 1
       position 0.25 0
       size 24 24
       valign center_ref
       hexactpos 0
       vexactpos 1
       hexactsize 1
       vexactsize 1
       image0 "set:vpp_icons image:copy"
       mode blend
       "src alpha" 1
       "stretch mode" stretch_w_h
       filter 1
      }
      TextWidgetClass txtExport {
       ignorepointer 1
