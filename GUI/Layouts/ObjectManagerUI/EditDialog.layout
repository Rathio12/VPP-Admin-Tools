       text "#VSTR_LBL_BLD_SET_ACTIVE"
       font "gui/fonts/sdf_MetronLight72"
       "exact text" 1
       "exact text size" 14
       "size to text h" 1
       "size to text v" 1
       "text valign" center
      }
     }
    }
    ButtonWidgetClass button_export {
     size 0.6 0.2
     halign center_ref
     valign center_ref
