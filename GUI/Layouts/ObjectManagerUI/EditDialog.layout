       vexactpos 0
       hexactsize 0
       vexactsize 0
       style None
       text "#VSTR_LBL_EXPORT_RAW"
       font "gui/fonts/sdf_MetronLight72"
       "bold text" 1
       "exact text" 1
       "exact text size" 13
       "size to text h" 1
       "size to text v" 1
       "text valign" center
      }
     }
    }
   }
