GridSpacerWidgetClass SpacerGrid {
 visible 1
 ignorepointer 1
 color 0 0 0 0
 position 0 0
 size 1 0
 hexactpos 1
 vexactpos 1
 hexactsize 0
 vexactsize 0
 style Colorable
 Padding 3
 Margin 0
 "Size To Content H" 1
 "Size To Content V" 1
 content_valign center
 Columns 2
 Rows 1
 {
  ImageWidgetClass IconHealth {
   position 0 0
   size 24 24
   valign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 1
   vexactsize 1
   image0 "set:vpp_icons image:heart_pulse"
   mode blend
   "src alpha" 1
   "stretch mode" stretch_w_h
   filter 1
  }
  PanelWidgetClass HealthTrack {
   ignorepointer 1
   color 1 1 1 1
   position 0 0
   size 150 10
   halign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 1
   vexactsize 1
   style VPPCard
   {
    PanelWidgetClass HealthInput {
     ignorepointer 1
     color 0.298 0.686 0.314 1
     position 0 0
     size 1 1
     hexactpos 0
     vexactpos 0
     hexactsize 0
     vexactsize 0
     style VPPFill
    }
   }
  }
  ImageWidgetClass IconBlood {
   position 0 0
   size 24 24
   valign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 1
   vexactsize 1
   image0 "set:vpp_icons image:droplets"
   mode blend
   "src alpha" 1
   "stretch mode" stretch_w_h
   filter 1
  }
  PanelWidgetClass BloodTrack {
   ignorepointer 1
   color 1 1 1 1
   position 4 0
   size 150 10
   valign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 1
   vexactsize 1
   style VPPCard
   {
    PanelWidgetClass BloodInput {
     ignorepointer 1
     color 0.298 0.686 0.314 1
     position 0 0
     size 1 1
     hexactpos 0
     vexactpos 0
     hexactsize 0
     vexactsize 0
     style VPPFill
    }
   }
  }
 }
}