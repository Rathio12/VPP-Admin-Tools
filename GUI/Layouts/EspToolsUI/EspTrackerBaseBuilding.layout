GridSpacerWidgetClass SpacerGrid {
 visible 1
 ignorepointer 1
 color 0 0 0 0
 position 0 0
 size 1 0
 hexactpos 1
 vexactpos 1
 hexactsize 0
 vexactsize 0
 style Colorable
 Padding 3
 Margin 2
 "Size To Content H" 1
 "Size To Content V" 1
 content_valign center
 Columns 2
 Rows 8
 {
  TextWidgetClass LblPasscode {
   color 0.604 0.627 0.651 1
   position 0 0
   size 0 12
   hexactpos 1
   vexactpos 1
   hexactsize 1
   vexactsize 1
   style None
   text "Passcode:"
   font "gui/fonts/sdf_MetronLight72"
   "exact text" 1
   "exact text size" 12
   "size to text h" 1
   "size to text v" 1
   "text valign" center
  }
  TextWidgetClass Passcode {
   color 0.91 0.639 0.239 1
   position 0 0
   size 0 13
   hexactpos 1
   vexactpos 1
   hexactsize 1
   vexactsize 1
   style None
   text "XXXXXX"
   font "gui/fonts/sdf_MetronLight72"
   "bold text" 1
   "exact text" 1
   "exact text size" 13
   "size to text h" 1
   "size to text v" 1
   "text valign" center
  }
  ButtonWidgetClass PassCodeCopy {
   color 1 1 1 1
   position 0 0
   size 64 20
   hexactpos 1
   vexactpos 1
   hexactsize 1
   vexactsize 1
   style VPPButton
   text "Copy"
   font "gui/fonts/sdf_MetronLight72"
   "exact text" 1
   "exact text size" 13
  }
  ButtonWidgetClass PassCodeReset {
   color 1 1 1 1
   position 0 0
   size 64 20
   hexactpos 1
   vexactpos 1
   hexactsize 1
   vexactsize 1
   style VPPButtonDanger
   text "Clear"
   font "gui/fonts/sdf_MetronLight72"
   "exact text" 1
   "exact text size" 13
  }
 }
}
