FrameWidgetClass EspItemRoot {
 clipchildren 1
 ignorepointer 0
 position 0 0
 size 1 28
 hexactpos 1
 vexactpos 1
 hexactsize 0
 vexactsize 1
 {
  PanelWidgetClass RowBg {
   ignorepointer 1
   color 0.078 0.086 0.094 0.85
   position 0 1
   size 1 26
   halign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 0
   vexactsize 1
   style VPPFillRound
  }
  ButtonWidgetClass btnRemoveItem {
   ignorepointer 0
   color 1 1 1 1
   position 4 0
   size 22 22
   valign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 1
   vexactsize 1
   scriptclass "ConfirmationEventHandler"
   style VPPButtonGhost
   "no focus" 1
   {
    ImageWidgetClass icon {
     ignorepointer 1
     color 0.604 0.627 0.651 1
     position 0 0
     size 24 24
     halign center_ref
     valign center_ref
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     image0 "set:vpp_icons image:x"
     mode blend
     "src alpha" 1
     "stretch mode" stretch_w_h
     filter 1
    }
   }
  }
