FrameWidgetClass FilterRowRoot {
 clipchildren 0
 ignorepointer 0
 position 0 0
 size 1 28
 hexactpos 1
 vexactpos 1
 hexactsize 0
 vexactsize 1
 {
  PanelWidgetClass RowBg {
   ignorepointer 1
   color 0.078 0.086 0.094 0.85
   position 0 1
   size 1 26
   halign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 0
   vexactsize 1
   style VPPFillRound
  }
  CheckBoxWidgetClass CheckBox {
   ignorepointer 0
   position 6 0
   size 0.52 22
   valign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 0
   vexactsize 1
   style VPPCheckBox
   text "FilterName"
   font "gui/fonts/sdf_MetronLight72"
  }
  ButtonWidgetClass btnColor {
   ignorepointer 0
   color 1 1 1 1
   position 32 0
   size 48 22
   halign right_ref
   valign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 1
   vexactsize 1
   style VPPButton
   {
    PanelWidgetClass colorSwatch {
     ignorepointer 1
     color 1 1 1 1
     position 5 0
     size 18 14
     valign center_ref
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     style VPPFillRound
    }
    ImageWidgetClass ImgColorChevron {
     ignorepointer 1
     color 0.604 0.627 0.651 1
     position 4 0
     size 16 16
     halign right_ref
     valign center_ref
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     image0 "set:vpp_icons image:chevron_down"
     mode blend
     "src alpha" 1
     "stretch mode" stretch_w_h
     filter 1
    }
   }
  }
  ButtonWidgetClass btnDeleteFilter {
   ignorepointer 0
   color 1 1 1 1
   position 4 0
   size 24 22
   halign right_ref
   valign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 1
   vexactsize 1
   style VPPButtonGhost
   {
    ImageWidgetClass iconDel {
     ignorepointer 1
     color 0.761 0.271 0.271 1
     position 0 0
     size 24 24
     halign center_ref
     valign center_ref
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     image0 "set:vpp_icons image:trash_2"
     mode blend
     "src alpha" 1
     "stretch mode" stretch_w_h
     filter 1
    }
   }
  }
 }
}