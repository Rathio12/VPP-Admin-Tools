PanelWidgetClass PanelEntry {
 ignorepointer 1
 keepsafezone 1
 color 0.106 0.118 0.133 0.85
 position 0 0
 size 0.99 24
 halign center_ref
 hexactpos 0
 vexactpos 0
 hexactsize 0
 vexactsize 1
 style VPPFillRound
 {
  TextWidgetClass ItemName {
   ignorepointer 1
   color 1 1 1 1
   position 8 0
   size 0.7 1
   valign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 0
   vexactsize 0
   style None
   text "WebHookName"
   font "gui/fonts/sdf_MetronLight72"
   "exact text" 1
   "exact text size" 13
   "size to text h" 1
   "size to text v" 0
   "text valign" center
  }
  ButtonWidgetClass btnEditItem {
   ignorepointer 0
   color 1 1 1 1
   position 30 0
   size 22 22
   halign right_ref
   valign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 1
   vexactsize 1
   scriptclass "ConfirmationEventHandler"
   style VPPButtonGhost
   "no focus" 1
   {
    ImageWidgetClass iconEdit {
     ignorepointer 1
     color 0.604 0.627 0.651 1
     position 0 0
     size 24 24
     halign center_ref
     valign center_ref
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     image0 "set:vpp_icons image:square_pen"
     mode blend
     "src alpha" 1
     "stretch mode" stretch_w_h
     filter 1
    }
   }
  }
  ButtonWidgetClass btnDeleteItem {
   ignorepointer 0
   color 1 1 1 1
   position 4 0
   size 22 22
   halign right_ref
   valign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 1
   vexactsize 1
   scriptclass "ConfirmationEventHandler"
   style VPPButtonGhost
   "no focus" 1
