PanelWidgetClass PanelPlayer {
 ignorepointer 1
 keepsafezone 1
 color 0.106 0.118 0.133 0.85
 size 1 24
 halign center_ref
 valign center_ref
 hexactpos 0
 vexactpos 0
 hexactsize 0
 vexactsize 1
 style VPPFillRound
 {
  ButtonWidgetClass btnRemoveUser {
   ignorepointer 0
   color 1 1 1 1
   position 3 0
   size 22 22
   valign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 1
   vexactsize 1
   scriptclass "ConfirmationEventHandler"
   style VPPButtonGhost
   "no focus" 1
   {
    ImageWidgetClass icon {
     ignorepointer 1
     color 0.761 0.271 0.271 1
     position 0 0
     size 24 24
     halign center_ref
     valign center_ref
     hexactpos 1
     vexactpos 1
     hexactsize 1
     vexactsize 1
     image0 "set:vpp_icons image:user_minus"
     mode blend
     "src alpha" 1
     "stretch mode" stretch_w_h
     filter 1
    }
   }
  }
  TextWidgetClass TxtPlayerName {
   ignorepointer 0
   color 1 1 1 1
   position 30 0
   size 0.5 1
   valign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 0
   vexactsize 0
   style None
   text "my names long"
   font "gui/fonts/sdf_MetronLight72"
   "exact text" 1
   "exact text size" 13
   "size to text h" 1
   "size to text v" 0
   "text valign" center
  }
  TextWidgetClass TextGUID {
   ignorepointer 1
   color 0.604 0.627 0.651 1
   position 8 0
   size 0.5 1
   halign right_ref
   valign center_ref
   hexactpos 1
   vexactpos 1
   hexactsize 0
   vexactsize 0
   style None
   text "12345678999999999"
   font "gui/fonts/sdf_MetronLight72"
   "exact text" 1
   "exact text size" 11
   "size to text h" 1
   "size to text v" 0
   "text halign" right
   "text valign" center
  }
 }
}