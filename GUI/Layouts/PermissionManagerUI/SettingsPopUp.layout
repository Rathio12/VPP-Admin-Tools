FrameWidgetClass rootFrame {
 clipchildren 1
 size 1 1
 halign center_ref
 valign center_ref
 hexactpos 0
 vexactpos 0
 hexactsize 0
 vexactsize 0
 {
  PanelWidgetClass mainPnl {
   inheritalpha 0
   color 0 0 0 1
   size 1 1
   halign center_ref
   valign center_ref
   hexactpos 0
   vexactpos 0
   hexactsize 0
   vexactsize 0
   style VPPFillRound
   {
    PanelWidgetClass titleBG {
     ignorepointer 1
     color 0.031 0.035 0.039 0.95
     position 0 0
     size 1 0.2
     halign center_ref
     hexactpos 0
     vexactpos 0
     hexactsize 0
     vexactsize 0
     style VPPFillRound
     {
      ImageWidgetClass ImgTitleIcon {
       ignorepointer 1
       color 0.91 0.639 0.239 1
       position 6 0
       size 24 24
       valign center_ref
       hexactpos 1
       vexactpos 1
       hexactsize 1
       vexactsize 1
       image0 "set:vpp_icons image:settings"
       mode blend
       "src alpha" 1
       "stretch mode" stretch_w_h
       filter 1
      }
      TextWidgetClass text_title {
       ignorepointer 1
       position 32 0
       size 0.85 1
       valign center_ref
       hexactpos 1
       vexactpos 1
       hexactsize 0
       vexactsize 0
       style None
       text "#VSTR_LBL_UPDATE_GROUP_ATTS"
       font "gui/fonts/sdf_MetronLight72"
       "bold text" 1
       "exact text" 1
       "exact text size" 15
       "size to text h" 1
       "size to text v" 1
       "text valign" center
      }
     }
    }
    MultilineTextWidgetClass info {
     ignorepointer 1
     color 0.604 0.627 0.651 1
     position 0.06 0.26
     size 0.88 0.3
     hexactpos 0
     vexactpos 0
     hexactsize 0
     vexactsize 0
     style None
     text "#VSTR_LBL_GROUP_NAME_FORCE"
     font "gui/fonts/sdf_MetronLight72"
     "exact text" 1
     "exact text size" 14
     "size to text h" 0
     "size to text v" 1
     wrap 1
     "condense whitespace" 1
     "strip newlines" 1
    }
    CheckBoxWidgetClass chkForceAdminName {
     ignorepointer 0
     position 0.06 0.59
     size 0.5 0.13
     hexactpos 0
     vexactpos 0
     hexactsize 0
     vexactsize 0
     style VPPCheckBox
     text "#VSTR_LBL_ENABLED"
     font "gui/fonts/sdf_MetronLight72"
    }
    PanelWidgetClass panel_buttons {
     ignorepointer 0
     color 0 0 0 0
     position 0.01 0.02
     size 0.96 0.16
     halign center_ref
     valign bottom_ref
     hexactpos 0
     vexactpos 0
     hexactsize 0
     vexactsize 0
     style blank
     {
      ButtonWidgetClass button_cancel {
       color 1 1 1 1
       position 0 0
       size 0.46 0.9
       valign center_ref
       hexactpos 0
       vexactpos 0
       hexactsize 0
       vexactsize 0
       style VPPButtonGhost
       font "gui/fonts/sdf_MetronLight72"
       "bold text" 1
       {
        TextWidgetClass LblCancel {
         ignorepointer 1
         size 1 1
         halign center_ref
         valign center_ref
         hexactpos 0
         vexactpos 0
         hexactsize 0
         vexactsize 0
         text "#VSTR_CANCEL"
         font "gui/fonts/sdf_MetronLight24"
         "exact text" 1
         "exact text size" 16
         "size to text h" 1
         "size to text v" 1
         "text halign" center
         "text valign" center
        }
       }
      }
      ButtonWidgetClass button_save {
       color 1 1 1 1
       position 0.01 0
       size 0.46 0.9
       halign right_ref
       valign center_ref
       hexactpos 0
       vexactpos 0
       hexactsize 0
       vexactsize 0
       style VPPButton
       font "gui/fonts/sdf_MetronLight72"
       "bold text" 1
       {
        TextWidgetClass LblSave {
         ignorepointer 1
         size 1 1
         halign center_ref
         valign center_ref
         hexactpos 0
         vexactpos 0
         hexactsize 0
         vexactsize 0
         text "#VSTR_LBL_SAVE"
         font "gui/fonts/sdf_MetronLight24"
         "bold text" 1
         "exact text" 1
         "exact text size" 16
         "size to text h" 1
         "size to text v" 1
         "text halign" center
         "text valign" center
        }
       }
      }
     }
    }
   }
  }
 }
}